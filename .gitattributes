# Enforce LF line endings for source files to avoid CRLF/prettier issues
* text=auto
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
.gitattributes text eol=lf
public/assets/SF-Pro.dmg filter=lfs diff=lfs merge=lfs -text
